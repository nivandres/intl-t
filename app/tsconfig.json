{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/.source": ["./.source/index.ts"],
      "fumadocs-mdx:collections/*": ["./.source/*"],
      "@/*": ["./*"],
      "@intl-t/*": ["../src/*"],
      "@intl-t/core": ["../packages/core/src"],
      "@intl-t/core/*": ["../packages/core/src/*"],
      "@intl-t/declarations": ["../packages/declarations/src"],
      "@intl-t/declarations/*": ["../packages/declarations/src/*"],
      "@intl-t/format": ["../packages/format/src"],
      "@intl-t/format/*": ["../packages/format/src/*"],
      "@intl-t/global": ["../packages/global/src"],
      "@intl-t/global/*": ["../packages/global/src/*"],
      "@intl-t/locales": ["../packages/locales/src"],
      "@intl-t/locales/*": ["../packages/locales/src/*"],
      "@intl-t/next": ["../packages/next/src"],
      "@intl-t/next/*": ["../packages/next/src/*"],
      "@intl-t/react": ["../packages/react/src"],
      "@intl-t/react/*": ["../packages/react/src/*"],
      "@intl-t/tools": ["../packages/tools/src"],
      "@intl-t/tools/*": ["../packages/tools/src/*"],
      "intl-t": ["../src/index.ts"],
      "intl-t/*": ["../src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": ["node_modules"]
}
